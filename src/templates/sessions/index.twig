{% extends "_layouts/cp.twig" %}

{% set title = "AI Sessions"|t('craft-ai') %}

{% block actionButton %}
    <form method="post" accept-charset="UTF-8">
        {{ csrfInput() }}
        {{ actionInput('craft-ai/sessions/new') }}
        <button type="submit" class="btn submit add icon">{{ "New Session"|t('craft-ai') }}</button>
    </form>
{% endblock %}

{% block content %}
    {% if sessions|length %}
        <table class="data fullwidth">
            <thead>
                <tr>
                    <th>{{ "Session"|t('craft-ai') }}</th>
                    <th>{{ "Messages"|t('craft-ai') }}</th>
                    <th>{{ "Started"|t('craft-ai') }}</th>
                    <th>{{ "Last activity"|t('craft-ai') }}</th>
                </tr>
            </thead>
            <tbody>
                {% for session in sessions %}
                    <tr>
                        <td>
                            <a href="{{ cpUrl('ai/session/' ~ session.sessionId) }}">
                                <code>{{ session.sessionId }}</code>
                            </a>
                        </td>
                        <td>{{ session.messageCount }}</td>
                        <td>{{ session.firstMessage ? session.firstMessage|date('short') ~ ' ' ~ session.firstMessage|time('short') : '' }}</td>
                        <td>{{ session.lastMessage ? session.lastMessage|date('short') ~ ' ' ~ session.lastMessage|time('short') : '' }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p>{{ "No sessions yet. Start one with the New Session button above."|t('craft-ai') }}</p>
    {% endif %}
{% endblock %}
