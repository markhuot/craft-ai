{% extends "_layouts/cp.twig" %}

{% set title = sessionTitle ?? "AI Sessions"|t('craft-ai') %}
{% set fullPageForm = false %}

{% do view.registerAssetBundle("markhuot\\craftai\\web\\assets\\chat\\ChatAsset") %}

{% if sessionId %}
    {% set actionMenu = disclosureMenu([
        {
            icon: 'circle-stop',
            label: 'Stop session'|t('craft-ai'),
            action: 'craft-ai/sessions/stop',
            params: {sessionId: sessionId},
            confirm: 'Stop this session? The agent will halt after its current step.'|t('craft-ai'),
            redirect: 'ai/session/'~sessionId,
        },
        {
            icon: 'trash',
            label: 'Delete session'|t('craft-ai'),
            destructive: true,
            action: 'craft-ai/sessions/delete',
            params: {sessionId: sessionId},
            confirm: 'Are you sure you want to delete this session and all of its messages?'|t('craft-ai'),
            redirect: 'ai/sessions',
        },
    ], {
        hiddenLabel: 'Actions'|t('app'),
        buttonAttributes: {
            class: ['action-btn'],
            title: 'Actions'|t('app'),
        },
    }) %}
{% endif %}

{% set bootstrap = {
    sessionId: sessionId,
    messagesUrl: actionUrl('craft-ai/messages'),
    sendUrl: actionUrl('craft-ai/sessions/send'),
    sessionsUrl: actionUrl('craft-ai/sessions/data'),
    newSessionUrl: actionUrl('craft-ai/sessions/new'),
    sessionsIndexUrl: cpUrl('ai/sessions'),
    assetsInfoUrl: actionUrl('craft-ai/assets/info'),
    csrfTokenName: craft.app.config.general.csrfTokenName,
    csrfTokenValue: craft.app.request.csrfToken,
    initialMessages: messages,
    initialSessions: initialSessions ?? [],
} %}

{% block content %}
    <div data-craftai-chat-root>
        <noscript>
            <p class="light">{{ "JavaScript is required to use the AI chat interface."|t('craft-ai') }}</p>
        </noscript>
        <script type="application/json" data-craftai-bootstrap>
            {{ bootstrap|json_encode(constant('JSON_HEX_TAG') b-or constant('JSON_HEX_AMP') b-or constant('JSON_HEX_APOS') b-or constant('JSON_HEX_QUOT'))|raw }}
        </script>
    </div>
{% endblock %}
